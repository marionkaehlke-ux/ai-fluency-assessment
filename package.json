{
  "name": "ai-fluency-scorer",
  "version": "0.1.0",
  "private": true,
  "description": "Internal Phrase application for AI fluency assessment",
  "workspaces": [
    "packages/*",
    "apps/*",
    "e2e"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test -w @ai-fluency/shared -w @ai-fluency/api -w @ai-fluency/web",
    "dev": "npm run dev --workspace @ai-fluency/api & npm run dev --workspace @ai-fluency/web",
    "dev:api": "npm run dev --workspace @ai-fluency/api",
    "dev:web": "npm run dev --workspace @ai-fluency/web",
    "db:generate": "npm run db:generate --workspace @ai-fluency/api",
    "db:migrate": "npm run db:migrate --workspace @ai-fluency/api",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "test:integration": "npm run test:integration --workspace @ai-fluency/api",
    "test:e2e": "npm run test --workspace @ai-fluency/e2e"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "overrides": {
    "ioredis": "^5.4.1"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "msgpackr-extract@3.0.4": true,
    "prisma@5.22.0": true
  }
}

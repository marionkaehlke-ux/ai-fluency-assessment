# Copy to .env for local development. NEVER commit a filled-in .env.
# In production these are injected by Launchpad (Secrets Manager / GitHub Actions secrets).

# --- Core ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database (local Docker Compose; prod injects DATABASE_URL from AWS Secrets Manager) ---
DATABASE_URL=postgresql://aifluency:aifluency@localhost:5432/aifluency?schema=public

# --- Redis / BullMQ (local Docker Compose) ---
REDIS_URL=redis://localhost:6379

# --- Anthropic Claude (server-side only; add via add-secret skill in prod) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Pinned model string — resolved from env, never hard-coded (spec §7.4)
CLAUDE_MODEL=claude-sonnet-4-5
ANTHROPIC_VERSION=2023-06-01
# Optional: override the Anthropic API base URL (unset in prod). E2E tests point this at a local mock.
# ANTHROPIC_BASE_URL=
# References prompts/scoring-rubric-v{n}.txt
SCORING_PROMPT_VERSION=v1

# --- Feature flags (spec §10.4 rollback uses SCORING_ENABLED) ---
SCORING_ENABLED=true
SLACK_NOTIFICATIONS_ENABLED=false

# --- Auth (local dev only) ---
# In production Okta injects X-Userinfo at the ingress gateway and AUTH_DEV_BYPASS MUST be unset/false.
# Locally, set a dev identity so you can exercise the app without the gateway.
AUTH_DEV_BYPASS=true
AUTH_DEV_EMAIL=marion.kaehlke@phrase.com
AUTH_DEV_NAME=Marion Kaehlke
AUTH_DEV_GROUPS=phrase-elt

# --- Role seeding (spec §3.1: ELT list is a People Ops static env var) ---
ELT_EMAILS=andrea.tabacchi@phrase.com,georg.ell@phrase.com,ian.woolley@phrase.com,jason.hemingway@phrase.com,martin.konop@phrase.com,marion.kaehlke@phrase.com,stephen.lumenta@phrase.com
# Okta group that maps to the ADMIN_CALIBRATOR / People Ops capability
ADMIN_CALIBRATOR_GROUP=phrase-people-ops

# --- Current assessment cycle (YYYY-H{1|2}) ---
CURRENT_CYCLE=2026-H1

# --- SMTP relay (Launchpad-managed; manager notifications, spec §4.4) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ai-fluency@phrase.com
APP_BASE_URL=http://localhost:5173
